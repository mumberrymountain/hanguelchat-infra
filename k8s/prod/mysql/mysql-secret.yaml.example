# 복제: MARIADB_REPLICATION_USER / MARIADB_REPLICATION_PASSWORD 가 비어 있으면 primary·slave 연결이 구성되지 않습니다.
# envFrom(secretRef) 로 전체 주입하므로 위 두 키를 Secret 에 반드시 포함하세요.
apiVersion: v1
kind: Secret

metadata:
  name: mysql-secret

type: Opaque
stringData:
  MARIADB_ROOT_PASSWORD:
  MARIADB_DATABASE: hangeul_chat
  MARIADB_USER: hangeul_user
  MARIADB_PASSWORD:
  MARIADB_REPLICATION_USER: repl_user
  MARIADB_REPLICATION_PASSWORD:

