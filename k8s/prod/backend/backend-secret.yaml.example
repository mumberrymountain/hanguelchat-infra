apiVersion: v1
kind: Secret

metadata:
  name: backend-secret

type: Opaque
stringData:
  SPRING_DATASOURCE_URL: jdbc:mysql://mysql-service:3306/hangeul_chat?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
  SPRING_DATASOURCE_USERNAME: hangeul_user
  SPRING_DATASOURCE_PASSWORD:
  # Redis: 비밀번호는 redis-secret 의 REDIS_PASSWORD 와 동일하게 맞출 것. 접속은 Sentinel(백엔드 Deployment env).
  SPRING_MAIN_LAZY_INITIALIZATION: "true"
  SPRING_DATASOURCE_HIKARI_INITIALIZATION_FAIL_TIMEOUT: "60000"
